# Shared secret the WordPress form webhook must send in the x-lead-secret header
LEAD_WEBHOOK_SECRET=

# Auth.js — generate with: npx auth secret (or openssl rand -base64 32)
AUTH_SECRET=
# Google OAuth client (console.cloud.google.com > APIs & Services > Credentials)
# Authorized redirect URI: <origin>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Firecrawl — https://firecrawl.dev (free 1K credits)
FIRECRAWL_API_KEY=

# Vercel AI Gateway — auto-provided on Vercel deploys; set for local dev
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
# Any gateway model string, e.g. deepseek/deepseek-chat or google/gemini-2.5-flash-lite
LLM_MODEL=google/gemini-2.5-flash-lite

# Vercel Blob — auto-provided when a Blob store is connected to the project
# (@vercel/blob v2 authenticates via VERCEL_OIDC_TOKEN + BLOB_STORE_ID; both come from `vercel env pull`)
BLOB_STORE_ID=

# MailerLite — https://dashboard.mailerlite.com/integrations/api
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
# Optional: verify webhook signatures (set the same secret on the MailerLite webhook)
MAILERLITE_WEBHOOK_SECRET=
# Sender for the PDF-delivery email (must be verified in MailerLite; use an authenticated domain for deliverability)
MAILERLITE_FROM_EMAIL=
MAILERLITE_FROM_NAME=

# Resend — preferred delivery path (attachment + link). Requires the sender
# domain to be verified at resend.com/domains. When unset — or if the Resend
# send fails — delivery falls back to a MailerLite campaign (link only).
RESEND_API_KEY=
# RESEND_FROM=Maggie | Captured Sites <maggie@capturedsites.com>

# Supabase — project settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# CTA link on the report's closing pages (default: https://capturedsites.com/tour/)
# CTA_URL=

# Abuse protection: hard cap on total lead submissions per rolling 24h (default 50)
# LEAD_DAILY_CAP=50

# Local dev only: path to a local Chrome for PDF generation
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
